{
  "$schema": "https://raw.githubusercontent.com/nicepkg/tauri2-schema-gen/main/tauri.conf.json",
  "productName": "Clokr NFC Terminal",
  "version": "0.1.0",
  "identifier": "com.clokr.nfc-client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev --port 1420",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clokr NFC Terminal",
        "label": "settings",
        "width": 480,
        "height": 440,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-disconnected.png",
      "iconAsTemplate": true,
      "tooltip": "Clokr NFC Terminal"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
