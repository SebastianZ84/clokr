# ============================================================
# Clokr Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=clokr
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=clokr
# Only needed for local dev (Docker Compose uses the above)
DATABASE_URL="postgresql://clokr:change-me-strong-password@localhost:5432/clokr"

# ── Security (REQUIRED — generate unique values!) ──────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-generate-a-64-char-hex-string
JWT_REFRESH_SECRET=change-me-generate-another-64-char-hex-string
ENCRYPTION_KEY=change-me-generate-yet-another-64-char-hex-string

# ── JWT Expiry ──────────────────────────────────────────────
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App URL (used for email links, CORS, cookies) ──────────
APP_URL=http://localhost:3000

# ── Ports (optional, defaults shown) ───────────────────────
# API_PORT=4000
# WEB_PORT=3000

# ── Image Version (for docker-compose.prod.yml) ────────────
# Pin to a specific version or use "latest"
CLOKR_VERSION=latest

# ── Seed Demo Data ──────────────────────────────────────────
# Set to true for first install to create admin user
SEED_DEMO_DATA=true

# ── NFC Terminal ────────────────────────────────────────────
# NFC terminals use API keys — manage in Admin → System → NFC-Terminals

# ── SMTP (optional — configure per tenant in Admin UI) ─────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=Clokr
# SMTP_SECURE=false

# ── MinIO / S3 (for file exports) ──────────────────────────
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
